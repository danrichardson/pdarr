@echo off
cd /d %~dp0

echo [1/3] Building frontend...
cd frontend
call npm run build
if %ERRORLEVEL% NEQ 0 ( echo FRONTEND BUILD FAILED & exit /b 1 )
cd ..

echo [2/3] Copying source to server...
scp -r internal cmd go.mod go.sum root@%DEPLOY_HOST%:/opt/sqzarr-src/
if %ERRORLEVEL% NEQ 0 ( echo SCP FAILED & exit /b 1 )

echo [3/3] Building binary and restarting service...
ssh -l root %DEPLOY_HOST% "cd /opt/sqzarr-src && go build -trimpath -ldflags='-s -w' -o /usr/local/bin/sqzarr ./cmd/sqzarr/ && systemctl restart sqzarr && sleep 1 && systemctl is-active sqzarr"
if %ERRORLEVEL% NEQ 0 ( echo REMOTE BUILD/RESTART FAILED & exit /b 1 )

echo DEPLOY OK
